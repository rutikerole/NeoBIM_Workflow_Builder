# NeoBIM Workflow Builder - Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================
# DATABASE (Neon PostgreSQL - serverless)
# ============================================================
# Pooled connection (used by app via Neon adapter)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neobim?sslmode=require"
# Direct connection (used by Prisma migrate/studio)
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neobim?sslmode=require"

# ============================================================
# REDIS
# ============================================================
REDIS_URL="redis://:neobim_redis_password@localhost:6379"

# ============================================================
# AUTH (NextAuth.js)
# ============================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here-generate-with-openssl-rand-base64-32"

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# ============================================================
# S3 / MINIO (Artifact Storage)
# ============================================================
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="neobim_minio"
S3_SECRET_ACCESS_KEY="neobim_minio_secret"
S3_BUCKET_NAME="neobim-artifacts"
S3_PUBLIC_URL="http://localhost:9000/neobim-artifacts"

# ============================================================
# EXTERNAL APIs (Optional - use platform keys or your own)
# ============================================================

# OpenAI
OPENAI_API_KEY="sk-..."

# Azure AI Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT="https://your-resource.cognitiveservices.azure.com/"
AZURE_DOCUMENT_INTELLIGENCE_KEY="your-azure-key"

# Stability AI
STABILITY_API_KEY="sk-..."

# Rhino.Compute
RHINO_COMPUTE_URL="http://localhost:8081"
RHINO_COMPUTE_API_KEY="your-rhino-compute-key"

# Speckle
SPECKLE_TOKEN="your-speckle-token"
SPECKLE_SERVER_URL="https://speckle.xyz"

# Google Maps / Mapbox
GOOGLE_MAPS_API_KEY="your-google-maps-key"
MAPBOX_TOKEN="your-mapbox-token"

# ============================================================
# APP CONFIGURATION
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="NeoBIM"
NEXT_PUBLIC_ENABLE_MOCK_EXECUTION="true"
NODE_ENV="development"

# ============================================================
# RATE LIMITING (Upstash Redis)
# ============================================================
# For production: use Upstash Redis REST API
UPSTASH_REDIS_REST_URL="https://your-redis-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
# For local development: use local Redis (already configured above in REDIS_URL)

# ============================================================
# STRIPE (Payment Processing)
# ============================================================
# Stripe secret key (test or production)
STRIPE_SECRET_KEY="sk_test_..."

# Stripe webhook secret (for webhook signature verification)
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe price IDs for subscription plans
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_TEAM_PRICE_ID="price_..."

# Public Stripe key (for frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
