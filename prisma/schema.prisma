generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String                 @id @default(cuid())
  email         String                 @unique
  name          String?
  image         String?
  emailVerified DateTime?
  password      String?
  role          UserRole               @default(FREE)
  bio           String?
  apiKeys       Json?                  @default("{}")
  stripeCustomerId        String?
  stripeSubscriptionId    String?
  stripePriceId           String?
  stripeCurrentPeriodEnd  DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  accounts      Account[]
  publications  CommunityPublication[]
  executions    Execution[]
  reviews       Review[]
  sessions      Session[]
  clones        WorkflowClone[]
  workflows     Workflow[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Workflow {
  id           String                 @id @default(cuid())
  ownerId      String
  name         String
  description  String?
  tags         String[]
  tileGraph    Json                   @default("{\"edges\": [], \"nodes\": []}")
  version      Int                    @default(1)
  isPublished  Boolean                @default(false)
  isTemplate   Boolean                @default(false)
  thumbnail    String?
  category     String?
  complexity   WorkflowComplexity     @default(SIMPLE)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  publications CommunityPublication[]
  executions   Execution[]
  tiles        TileInstance[]
  clones       WorkflowClone[]
  owner        User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([isTemplate])
  @@map("workflows")
}

model TileInstance {
  id            String     @id @default(cuid())
  workflowId    String
  tileType      String
  positionX     Float      @default(0)
  positionY     Float      @default(0)
  configuration Json       @default("{}")
  createdAt     DateTime   @default(now())
  artifacts     Artifact[]
  workflow      Workflow   @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@map("tile_instances")
}

model Execution {
  id           String          @id @default(cuid())
  workflowId   String
  userId       String
  status       ExecutionStatus @default(PENDING)
  startedAt    DateTime?
  completedAt  DateTime?
  tileResults  Json            @default("[]")
  errorMessage String?
  createdAt    DateTime        @default(now())
  artifacts    Artifact[]
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflow     Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([userId])
  @@map("executions")
}

model Artifact {
  id             String       @id @default(cuid())
  executionId    String
  tileInstanceId String
  type           ArtifactType
  dataUri        String?
  data           Json?
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())
  execution      Execution    @relation(fields: [executionId], references: [id], onDelete: Cascade)
  tileInstance   TileInstance @relation(fields: [tileInstanceId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@map("artifacts")
}

model CommunityPublication {
  id           String   @id @default(cuid())
  workflowId   String
  authorId     String
  title        String
  description  String
  tags         String[]
  thumbnailUri String?
  ratingAvg    Float    @default(0)
  cloneCount   Int      @default(0)
  version      Int      @default(1)
  isFeatured   Boolean  @default(false)
  isReported   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  author       User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  workflow     Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  reviews      Review[]

  @@index([authorId])
  @@index([ratingAvg])
  @@index([cloneCount])
  @@map("community_publications")
}

model Review {
  id            String               @id @default(cuid())
  publicationId String
  userId        String
  stars         Int
  comment       String?
  createdAt     DateTime             @default(now())
  publication   CommunityPublication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([publicationId, userId])
  @@map("reviews")
}

model WorkflowClone {
  id         String   @id @default(cuid())
  workflowId String
  userId     String
  sourceId   String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([userId])
  @@map("workflow_clones")
}

enum UserRole {
  FREE
  PRO
  TEAM_ADMIN
  PLATFORM_ADMIN
}

enum WorkflowComplexity {
  SIMPLE
  INTERMEDIATE
  ADVANCED
}

enum ExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum ArtifactType {
  TEXT
  JSON
  IMAGE
  THREE_D
  FILE
  TABLE
  KPI
}
